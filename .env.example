# --- 模型權重路徑 ---
# 填寫你訓練好的 YOLO 權重路徑
POSE_MODEL_PATH=weights/best.pt
SEG_MODEL_PATH=weights/yolo11n-seg.pt

# --- API 安全性設定 ---
# 使用者正式部署時要修改
API_USERNAME=guest_user
API_PASSWORD=animal_test_2026

# --- 推論參數設定 ---
# 信心程度閾值 (0.0 ~ 1.0)
CONF_THRESHOLD=0.25
# 影像輸入大小
IMG_SIZE=640

# --- 目錄設定 ---
RAW_IMAGE_DIR=raw_images
RESULT_DIR=results